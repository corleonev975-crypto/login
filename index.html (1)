<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>XINN LINK - Cyberpunk Admin System</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        /* ========== CYBERPUNK THEME ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Space Grotesk', 'Segoe UI', monospace;
            background: #05070f;
            overflow-x: hidden;
        }

        /* Background */
        .cyber-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -2;
            background: radial-gradient(circle at 20% 30%, #0a0e1c, #020308);
        }

        .grid-overlay {
            position: fixed;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(rgba(0, 255, 255, 0.05) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(0, 255, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            animation: gridMove 20s linear infinite;
            z-index: -1;
            pointer-events: none;
        }

        @keyframes gridMove {
            0% { transform: translate(0, 0); }
            100% { transform: translate(40px, 40px); }
        }

        .glow-orb {
            position: fixed;
            width: 500px;
            height: 500px;
            background: radial-gradient(circle, rgba(0, 255, 255, 0.12), transparent 70%);
            border-radius: 50%;
            filter: blur(90px);
            top: -150px;
            right: -100px;
            animation: floatGlow 12s infinite alternate;
            z-index: -1;
        }

        .glow-orb2 {
            bottom: -150px;
            left: -100px;
            top: auto;
            background: radial-gradient(circle, rgba(255, 0, 200, 0.1), transparent 70%);
            animation: floatGlow2 15s infinite alternate;
        }

        @keyframes floatGlow {
            0% { transform: translate(0, 0) scale(1); opacity: 0.5; }
            100% { transform: translate(60px, 50px) scale(1.2); opacity: 0.8; }
        }

        @keyframes floatGlow2 {
            0% { transform: translate(0, 0) scale(1); }
            100% { transform: translate(-50px, -70px) scale(1.3); }
        }

        /* Toast */
        .toast-msg {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #000000dd;
            backdrop-filter: blur(20px);
            border-left: 5px solid cyan;
            padding: 12px 28px;
            border-radius: 40px;
            color: cyan;
            font-weight: 500;
            z-index: 200;
            opacity: 0;
            transition: 0.2s;
            pointer-events: none;
            font-family: monospace;
        }

        .toast-msg.show {
            opacity: 1;
        }

        /* Login Section */
        .login-section {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .cyber-card {
            background: rgba(8, 12, 28, 0.8);
            backdrop-filter: blur(16px);
            border: 1.5px solid rgba(0, 255, 255, 0.6);
            border-radius: 40px;
            max-width: 460px;
            width: 100%;
            padding: 2.5rem 2rem;
            box-shadow: 0 0 40px rgba(0, 255, 255, 0.2);
            transition: 0.3s;
        }

        .cyber-card:hover {
            border-color: #ff44ee;
            box-shadow: 0 0 45px rgba(255, 68, 238, 0.3);
        }

        .brand {
            text-align: center;
            margin-bottom: 30px;
        }

        .brand h1 {
            font-size: 2.8rem;
            font-weight: 800;
            background: linear-gradient(135deg, #0ff, #f0f);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 0 0 12px cyan;
        }

        .brand-tag {
            border-top: 1px solid cyan;
            border-bottom: 1px solid cyan;
            display: inline-block;
            padding: 5px 20px;
            font-size: 0.8rem;
            color: #aaffff;
        }

        /* Input */
        .input-group {
            margin-bottom: 1.5rem;
            position: relative;
        }

        .input-group i {
            position: absolute;
            left: 20px;
            top: 50%;
            transform: translateY(-50%);
            color: #0ff;
            font-size: 1.2rem;
            z-index: 2;
        }

        .input-group input {
            width: 100%;
            background: rgba(0, 20, 35, 0.7);
            border: 1px solid #0ff;
            border-radius: 60px;
            padding: 14px 20px 14px 48px;
            color: #eef5ff;
            font-family: monospace;
            font-size: 1rem;
            outline: none;
            transition: 0.2s;
        }

        .input-group input:focus {
            border-color: #ff44ee;
            box-shadow: 0 0 12px #ff44ee;
        }

        /* Button */
        .login-btn {
            width: 100%;
            background: linear-gradient(95deg, #0ff, #f0f);
            border: none;
            border-radius: 60px;
            padding: 14px;
            font-weight: bold;
            font-size: 1.1rem;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 8px;
            font-family: monospace;
        }

        .login-btn:hover {
            transform: scale(1.02);
            box-shadow: 0 0 20px magenta;
        }

        /* Dashboard */
        .dashboard {
            display: none;
            padding: 20px;
        }

        .dashboard.active {
            display: block;
            animation: fadeInUp 0.5s;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .cyber-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            background: rgba(0, 10, 20, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid cyan;
            border-radius: 80px;
            padding: 12px 28px;
            margin-bottom: 30px;
        }

        .logo-nav {
            font-size: 1.6rem;
            font-weight: bold;
            background: linear-gradient(135deg, cyan, magenta);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        .user-info {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .user-badge {
            background: rgba(0, 255, 255, 0.2);
            padding: 6px 20px;
            border-radius: 40px;
            border: 1px solid cyan;
        }

        .logout-btn, .admin-panel-btn {
            background: none;
            border: 1px solid magenta;
            padding: 6px 20px;
            border-radius: 40px;
            color: magenta;
            cursor: pointer;
            transition: 0.2s;
            font-family: monospace;
        }

        .logout-btn:hover, .admin-panel-btn:hover {
            background: magenta;
            color: black;
        }

        /* Stats */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }

        .cyber-stat {
            background: rgba(0, 15, 25, 0.6);
            backdrop-filter: blur(8px);
            border: 1px solid cyan;
            border-radius: 28px;
            padding: 22px;
            transition: 0.2s;
        }

        .cyber-stat:hover {
            transform: translateY(-4px);
            border-color: magenta;
        }

        .stat-title {
            color: #88ffff;
            font-size: 0.85rem;
            letter-spacing: 2px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: bold;
            color: white;
            text-shadow: 0 0 8px cyan;
        }

        /* Admin Panel */
        .admin-panel {
            margin-top: 30px;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(12px);
            border: 2px solid magenta;
            border-radius: 32px;
            padding: 24px;
            display: none;
        }

        .admin-panel.show {
            display: block;
        }

        .admin-title {
            font-size: 1.4rem;
            color: magenta;
            border-bottom: 2px solid magenta;
            display: inline-block;
            margin-bottom: 20px;
        }

        .user-table {
            width: 100%;
            border-collapse: collapse;
            color: cyan;
        }

        .user-table th, .user-table td {
            padding: 12px;
            text-align: left;
            border-bottom: 1px solid rgba(0, 255, 255, 0.3);
        }

        .user-table th {
            color: #ff88ff;
        }

        .role-badge {
            background: magenta;
            color: black;
            padding: 3px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: bold;
            display: inline-block;
        }

        .role-badge.user {
            background: cyan;
        }

        .delete-user {
            background: none;
            border: 1px solid #ff3366;
            color: #ff3366;
            padding: 5px 14px;
            border-radius: 20px;
            cursor: pointer;
        }

        .delete-user:hover {
            background: #ff3366;
            color: black;
        }

        .add-user-form {
            display: flex;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .add-user-form input, .add-user-form select {
            background: #0a1428;
            border: 1px solid cyan;
            padding: 10px 16px;
            border-radius: 40px;
            color: white;
            font-family: monospace;
            flex: 1;
        }

        .add-user-form button {
            background: cyan;
            border: none;
            padding: 10px 24px;
            border-radius: 40px;
            font-weight: bold;
            cursor: pointer;
        }

        @media (max-width: 680px) {
            .cyber-nav { flex-direction: column; }
            .brand h1 { font-size: 2rem; }
            .user-table { font-size: 0.8rem; }
            .user-table th, .user-table td { padding: 8px; }
        }
    </style>
</head>
<body>
<div class="cyber-bg"></div>
<div class="grid-overlay"></div>
<div class="glow-orb"></div>
<div class="glow-orb glow-orb2"></div>

<!-- LOGIN SECTION -->
<div id="loginSection" class="login-section">
    <div class="cyber-card">
        <div class="brand">
            <h1><i class="fas fa-crown"></i> XINN LINK</h1>
            <div class="brand-tag">
                <i class="fas fa-shield-haltered"></i> by XINN GANTENG <i class="fas fa-skull"></i>
            </div>
            <div style="margin-top: 12px; font-size: 11px; color: #0ff;">// ADMIN ACCESS ONLY //</div>
        </div>
        <form id="loginFormMain">
            <div class="input-group">
                <i class="fas fa-user-secret"></i>
                <input type="text" id="loginUsername" placeholder="USERNAME" autocomplete="off">
            </div>
            <div class="input-group">
                <i class="fas fa-key"></i>
                <input type="password" id="loginPassword" placeholder="PASSWORD">
            </div>
            <button type="submit" class="login-btn"><i class="fas fa-plug"></i> LOGIN</button>
        </form>
        <div style="text-align: center; margin-top: 20px; font-size: 11px; color: #aaf;">
            ⚡ XINN NETWORK v3.0 ⚡
        </div>
    </div>
</div>

<!-- DASHBOARD -->
<div id="dashboard" class="dashboard">
    <div class="cyber-nav">
        <div class="logo-nav"><i class="fas fa-link"></i> XINN ADMIN</div>
        <div class="user-info">
            <div class="user-badge" id="dashboardUser">OPERATOR</div>
            <button id="toggleAdminBtn" class="admin-panel-btn"><i class="fas fa-laptop-code"></i> ADMIN MODE</button>
            <button id="logoutBtnDashboard" class="logout-btn"><i class="fas fa-sign-out-alt"></i> LOGOUT</button>
        </div>
    </div>

    <div class="stats-grid">
        <div class="cyber-stat">
            <div class="stat-title">SYSTEM STATUS</div>
            <div class="stat-value" id="sysStatus">ONLINE</div>
        </div>
        <div class="cyber-stat">
            <div class="stat-title">TOTAL USERS</div>
            <div class="stat-value" id="totalUsers">0</div>
        </div>
        <div class="cyber-stat">
            <div class="stat-title">ADMIN LEVEL</div>
            <div class="stat-value" id="adminLevel">-</div>
        </div>
    </div>

    <!-- ADMIN PANEL -->
    <div id="adminPanel" class="admin-panel">
        <div class="admin-title"><i class="fas fa-user-edit"></i> USER MANAGEMENT</div>
        <table class="user-table">
            <thead>
                <tr><th>USERNAME</th><th>ROLE</th><th>STATUS</th><th>ACTION</th></tr>
            </thead>
            <tbody id="userTableBody"></tbody>
        </table>
        <div class="add-user-form">
            <input type="text" id="newUsername" placeholder="New Username">
            <input type="password" id="newPassword" placeholder="Password">
            <select id="newRole">
                <option value="user">USER</option>
                <option value="admin">ADMIN</option>
            </select>
            <button id="addUserBtn"><i class="fas fa-plus"></i> ADD</button>
        </div>
    </div>
</div>

<div id="globalToast" class="toast-msg">⚡ SYSTEM READY ⚡</div>

<script>
    // ========== DATABASE ==========
    let users = [
        { id: 1, username: "xinn", password: "ganteng", role: "admin" },
        { id: 2, username: "admin", password: "cyber2024", role: "admin" },
        { id: 3, username: "operator", password: "xinn123", role: "user" },
        { id: 4, username: "netrunner", password: "cyberpunk", role: "user" }
    ];

    let currentUser = null;
    let adminPanelVisible = false;

    // ========== DOM ELEMENTS ==========
    const loginSection = document.getElementById('loginSection');
    const dashboardDiv = document.getElementById('dashboard');
    const usernameInput = document.getElementById('loginUsername');
    const passwordInput = document.getElementById('loginPassword');
    const loginForm = document.getElementById('loginFormMain');
    const toast = document.getElementById('globalToast');
    const dashboardUserSpan = document.getElementById('dashboardUser');
    const totalUsersSpan = document.getElementById('totalUsers');
    const adminLevelSpan = document.getElementById('adminLevel');
    const toggleAdminBtn = document.getElementById('toggleAdminBtn');
    const adminPanelDiv = document.getElementById('adminPanel');
    const userTableBody = document.getElementById('userTableBody');
    const addUserBtn = document.getElementById('addUserBtn');
    const newUsername = document.getElementById('newUsername');
    const newPassword = document.getElementById('newPassword');
    const newRole = document.getElementById('newRole');
    const logoutBtn = document.getElementById('logoutBtnDashboard');

    // ========== FUNCTIONS ==========
    function showToast(msg, isError = false) {
        toast.textContent = isError ? `⚠️ ${msg} ⚠️` : `✨ ${msg} ✨`;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 2500);
    }

    function renderUserTable() {
        if (!userTableBody) return;
        userTableBody.innerHTML = '';
        users.forEach(user => {
            const row = document.createElement('tr');
            let canDelete = (currentUser && currentUser.role === 'admin');
            if (user.role === 'admin' && currentUser?.username !== user.username) {
                canDelete = false;
            }
            row.innerHTML = `
                <td>${user.username}</td>
                <td><span class="role-badge ${user.role === 'admin' ? '' : 'user'}">${user.role.toUpperCase()}</span></td>
                <td style="color:#0f0;">ACTIVE</td>
                <td>${canDelete ? `<button class="delete-user" data-id="${user.id}"><i class="fas fa-trash"></i> Hapus</button>` : 'PROTECTED'}</td>
            `;
            userTableBody.appendChild(row);
        });
        document.querySelectorAll('.delete-user').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = parseInt(btn.getAttribute('data-id'));
                const targetUser = users.find(u => u.id === id);
                if (targetUser && targetUser.username === currentUser?.username) {
                    showToast("Tidak bisa menghapus akun sendiri!", true);
                    return;
                }
                users = users.filter(u => u.id !== id);
                showToast(`User ${targetUser?.username} telah dihapus`);
                updateTotalUsers();
                if (adminPanelVisible) renderUserTable();
                saveToStorage();
            });
        });
    }

    function addNewUser() {
        const uname = newUsername.value.trim();
        const pwd = newPassword.value.trim();
        const role = newRole.value;
        if (!uname || !pwd) {
            showToast("Isi semua field!", true);
            return;
        }
        if (users.find(u => u.username === uname)) {
            showToast("Username sudah ada!", true);
            return;
        }
        users.push({ id: Date.now(), username: uname, password: pwd, role: role });
        showToast(`User ${uname} ditambahkan sebagai ${role.toUpperCase()}`);
        newUsername.value = '';
        newPassword.value = '';
        updateTotalUsers();
        if (adminPanelVisible) renderUserTable();
        saveToStorage();
    }

    function updateTotalUsers() {
        totalUsersSpan.innerText = users.length;
    }

    function updateDashboardUI(user) {
        currentUser = user;
        dashboardUserSpan.innerHTML = `${user.username.toUpperCase()} [${user.role.toUpperCase()}]`;
        if (user.role === 'admin') {
            adminLevelSpan.innerHTML = 'SUPER ADMIN';
            toggleAdminBtn.style.display = 'inline-block';
        } else {
            adminLevelSpan.innerHTML = 'MEMBER';
            toggleAdminBtn.style.display = 'none';
            adminPanelDiv.classList.remove('show');
            adminPanelVisible = false;
        }
        updateTotalUsers();
    }

    function saveToStorage() {
        sessionStorage.setItem('xinn_users', JSON.stringify(users));
    }

    function loadFromStorage() {
        const stored = sessionStorage.getItem('xinn_users');
        if (stored) {
            try {
                users = JSON.parse(stored);
            } catch(e) {}
        }
    }

    // ========== LOGIN ==========
    loginForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const username = usernameInput.value.trim();
        const password = passwordInput.value;
        if (!username || !password) {
            showToast("Isi username dan password!", true);
            return;
        }
        const found = users.find(u => u.username === usern